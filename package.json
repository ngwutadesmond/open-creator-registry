{
  "name": "open-creator-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An open registry of creator-handle protection classifications.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "node scripts/run-local-workers.mjs",
    "dev:public": "npm run dev --workspace @open-creator-registry/public",
    "dev:admin": "npm run dev --workspace @open-creator-registry/admin",
    "db:inspect:local": "tsx packages/database/scripts/local-d1.ts inspect",
    "db:migrate:local": "tsx packages/database/scripts/local-d1.ts migrate",
    "db:migrations:list": "tsx packages/database/scripts/local-d1.ts list",
    "db:reset:local": "tsx packages/database/scripts/local-d1.ts reset",
    "db:seed:local": "tsx packages/database/scripts/local-d1.ts seed",
    "db:validate": "tsx packages/database/scripts/local-d1.ts validate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ingestion:serve:local": "WRANGLER_WRITE_LOGS=false wrangler dev --config apps/admin/wrangler.scheduled-local.jsonc --local --persist-to .wrangler/state --test-scheduled --port 8788",
    "ingestion:trigger:local": "node scripts/trigger-local-ingestion.mjs",
    "lint": "eslint . --max-warnings 0",
    "test": "npm run test:unit && npm run test:frontend && npm run test:database && npm run test:api && npm run test:admin-api",
    "test:admin-api": "vitest run --config vitest.admin-api.config.ts",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:database": "vitest run --config vitest.database.config.ts",
    "test:e2e": "npm run db:reset:local && playwright test",
    "test:frontend": "vitest run --config vitest.frontend.config.ts",
    "test:ingestion": "vitest run packages/ingestion/src/wikidata.test.ts --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit",
    "types:worker:public": "npm run types:worker --workspace @open-creator-registry/public",
    "types:worker:admin": "npm run types:worker --workspace @open-creator-registry/admin"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260721.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "miniflare": "^4.0.0",
    "prettier": "^3.9.6",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.68.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.9.0"
}
