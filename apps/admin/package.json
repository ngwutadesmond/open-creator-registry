{
  "name": "@open-creator-registry/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node ../../scripts/prepare-scalar-assets.mjs",
    "predev": "node ../../scripts/prepare-scalar-assets.mjs",
    "build": "WRANGLER_WRITE_LOGS=false vite build && node ../../scripts/sanitize-cloudflare-build.mjs dist",
    "dev": "WRANGLER_WRITE_LOGS=false vite --port 5174 --strictPort",
    "preview": "vite preview --port 4174 --strictPort",
    "typecheck": "tsc --noEmit",
    "types:worker": "WRANGLER_WRITE_LOGS=false wrangler types src/worker-configuration.d.ts --env-interface AdminBindings --include-runtime false --env-file ../../.env.types && prettier --write src/worker-configuration.d.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.5.1",
    "@open-creator-registry/contracts": "*",
    "@open-creator-registry/database": "*",
    "@open-creator-registry/ingestion": "*",
    "@open-creator-registry/normalization": "*",
    "@open-creator-registry/ui": "*",
    "@scalar/api-reference": "^1.63.0",
    "@scalar/hono-api-reference": "^0.11.11",
    "hono": "^4.0.0",
    "jose": "^6.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.2.8",
    "react-router": "^8.2.0",
    "zod": "^4.4.3"
  }
}
